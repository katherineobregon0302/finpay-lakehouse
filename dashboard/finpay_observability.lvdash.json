{
  "datasets": [
    {
      "name": "97e1bbc3",
      "displayName": "pipeline_summary",
      "queryLines": [
        "-- Registros en Bronze\n",
        "SELECT 'bronze' AS capa, 'transactions' AS fuente,\n",
        "    COUNT(*) AS registros_entrada,\n",
        "    COUNT(*) AS registros_ok,\n",
        "    0 AS registros_rechazados\n",
        "FROM fintech_finpay.bronze.transactions\n",
        "\n",
        "UNION ALL\n",
        "SELECT 'bronze', 'merchants',\n",
        "    COUNT(*), COUNT(*), 0\n",
        "FROM fintech_finpay.bronze.merchants\n",
        "\n",
        "UNION ALL\n",
        "SELECT 'bronze', 'users',\n",
        "    COUNT(*), COUNT(*), 0\n",
        "FROM fintech_finpay.bronze.users\n",
        "\n",
        "UNION ALL\n",
        "-- Registros en Silver (ok)\n",
        "SELECT 'silver', 'transactions',\n",
        "    (SELECT COUNT(*) FROM fintech_finpay.bronze.transactions),\n",
        "    COUNT(*),\n",
        "    (SELECT COUNT(*) FROM fintech_finpay.bronze.transactions) - COUNT(*)\n",
        "FROM fintech_finpay.silver.transactions\n",
        "\n",
        "UNION ALL\n",
        "SELECT 'silver', 'merchants',\n",
        "    (SELECT COUNT(*) FROM fintech_finpay.bronze.merchants),\n",
        "    COUNT(*),\n",
        "    (SELECT COUNT(*) FROM fintech_finpay.bronze.merchants) - COUNT(*)\n",
        "FROM fintech_finpay.silver.merchants\n",
        "\n",
        "UNION ALL\n",
        "SELECT 'silver', 'users',\n",
        "    (SELECT COUNT(*) FROM fintech_finpay.bronze.users),\n",
        "    COUNT(*),\n",
        "    (SELECT COUNT(*) FROM fintech_finpay.bronze.users) - COUNT(*)\n",
        "FROM fintech_finpay.silver.users\n",
        "\n",
        "UNION ALL\n",
        "-- Registros en Gold\n",
        "SELECT 'gold', 'reversal_rate',\n",
        "    (SELECT COUNT(*) FROM fintech_finpay.silver.transactions),\n",
        "    COUNT(*), 0\n",
        "FROM fintech_finpay.gold.reversal_rate\n",
        "\n",
        "UNION ALL\n",
        "SELECT 'gold', 'risk_score',\n",
        "    (SELECT COUNT(*) FROM fintech_finpay.silver.merchants),\n",
        "    COUNT(*), 0\n",
        "FROM fintech_finpay.gold.risk_score\n",
        "\n",
        "UNION ALL\n",
        "SELECT 'gold', 'channel_anomalies',\n",
        "    (SELECT COUNT(*) FROM fintech_finpay.silver.transactions),\n",
        "    COUNT(*), 0\n",
        "FROM fintech_finpay.gold.channel_anomalies"
      ]
    },
    {
      "name": "6fe735ca",
      "displayName": "top_riesgo",
      "queryLines": [
        "SELECT \n",
        "    merchant_id, \n",
        "    merchant_name, \n",
        "    risk_level, \n",
        "    tasa_reversa, \n",
        "    risk_score\n",
        "FROM fintech_finpay.gold.risk_score\n",
        "WHERE risk_score IS NOT NULL\n",
        "ORDER BY risk_score DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "6180473e",
      "displayName": "anomalias_por_canal",
      "queryLines": [
        "SELECT \n",
        "    channel,\n",
        "    COUNT(*) AS total_anomalias,\n",
        "    ROUND(AVG(amount), 2) AS monto_promedio_anomalia\n",
        "FROM fintech_finpay.gold.channel_anomalies\n",
        "GROUP BY channel\n",
        "ORDER BY total_anomalias DESC"
      ]
    }
  ],
